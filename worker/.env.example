CONVEX_URL=
WORKER_SECRET=
POLL_INTERVAL_MS=5000

# Supported: GENERATE_AC, GENERATE_PLAN
CLAIM_JOB_TYPE=GENERATE_AC

# Supported: anthropic, bedrock-anthropic, gemini, openai, openai-compatible, openrouter
CONTEXT_MODEL_PROVIDER=bedrock-anthropic

# For bedrock-anthropic, use the Bedrock model ID, for example:
# anthropic.claude-3-5-sonnet-20241022-v2:0
CONTEXT_MODEL_NAME=
CONTEXT_MODEL_API_KEY=
CONTEXT_MODEL_BASE_URL=
CONTEXT_MODEL_TIMEOUT_MS=60000

# Required for bedrock-anthropic.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

FORGE_BIN=forge
FORGE_AGENT=
FORGE_PROMPT_FLAG=--prompt
FORGE_TIMEOUT_MS=300000

# Set at least one Forge provider authentication variable.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
OPENROUTER_API_KEY=
FORGE_PROVIDER_API_KEY=
